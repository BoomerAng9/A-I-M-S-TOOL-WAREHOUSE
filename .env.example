# A.I.M.S. Tool Warehouse — environment.
# Copy to `.env` and fill in. NEVER commit a real `.env` (see .gitignore).

# Shared service token gating the catalog routes (X-Service-Token header).
# Leave UNSET to run open on loopback only; SET it to gate on a shared network.
# Generate one with:  openssl rand -hex 32
TOOL_WAREHOUSE_TOKEN=

# Override the bundled example seed with a full inventory file (JSONL).
# TOOL_WAREHOUSE_DATA=/data/foai-tool-inventory-log.jsonl

# Optional integration adapters — base URLs for the live-health checks on
# /integrations/health. Leave unset to report `not_configured`.
CODER_BASE_URL=
AUTOBASE_BASE_URL=
FILEDROP_BASE_URL=
HERMES_BASE_URL=

# Optional per-adapter tokens (sent as Authorization: Bearer on health checks).
# CODER_TOKEN=
# AUTOBASE_TOKEN=
# FILEDROP_TOKEN=
# HERMES_TOKEN=
