# A.I.M.S. Tool Warehouse — environment.
# Copy to `.env` and fill in. NEVER commit a real `.env` (see .gitignore).

# Shared service token gating the catalog routes (X-Service-Token header).
# Leave UNSET to run open on loopback only; SET it to gate on a shared network.
# Generate one with:  openssl rand -hex 32
TOOL_WAREHOUSE_TOKEN=

# Override the bundled example seed with a full inventory file (JSONL).
# TOOL_WAREHOUSE_DATA=/data/foai-tool-inventory-log.jsonl

# Optional integration adapters — base URLs for the live-health checks on
# /integrations/health. Leave unset to report `not_configured`.
CODER_BASE_URL=
AUTOBASE_BASE_URL=
FILEDROP_BASE_URL=
HERMES_BASE_URL=

# Optional per-adapter tokens (sent as Authorization: Bearer on health checks).
# CODER_TOKEN=
# AUTOBASE_TOKEN=
# FILEDROP_TOKEN=
# HERMES_TOKEN=

# --- Tenant API-key hashing (HMAC pepper). Strongly recommended in production:
# rotating in a pepper upgrades stored hashes v1(SHA256) -> v2(HMAC) without
# invalidating existing keys (scheme-tagged). Generate: openssl rand -hex 32
WAREHOUSE_KEY_PEPPER=

# --- Stripe paywall. Leave UNSET to keep the paywall gracefully OFF (checkout/
# claim return 503, webhook 503). Place the TEST keys first, verify end-to-end,
# THEN swap in the live keys. The webhook secret is per-endpoint (Stripe Dashboard
# -> Webhooks -> your endpoint). secret + webhook secret are SEPARATE secrets.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public base URL used to build Stripe success/cancel URLs (no trailing slash).
WAREHOUSE_PUBLIC_URL=https://warehouse.aimanagedsolutions.cloud

# How many catalog requests the one-time "Buy Me a Coffee" ($6.54) entry grants.
# Owner-tunable (recorded now; enforced in the LUC metering phase).
WAREHOUSE_COFFEE_CREDITS=100

# Email delivery of the minted API key (Resend) — used for EXTERNAL payments
# (a Paperform stepper / payment link) that have no in-app claim page. Leave
# RESEND_API_KEY unset to keep the in-app claim flow only. RESEND_FROM must be a
# VERIFIED Resend sender; the default uses Resend's onboarding sender so test mode
# works before you verify aimanagedsolutions.cloud.
# RESEND_API_KEY=
RESEND_FROM=A.I.M.S. Tool Warehouse <onboarding@resend.dev>
